{
  "name": "note-taking-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web --offline",
    "test": "jest --passWithNoTests",
    "test:ci": "jest --passWithNoTests --ci --coverage",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:ci": "eslint . --ext .ts,.tsx --max-warnings 0",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "^55.0.6",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^1.24.0",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/stack": "^7.8.4",
    "expo": "~55.0.5",
    "expo-av": "^16.0.8",
    "expo-document-picker": "^12.0.0",
    "expo-file-system": "~18.0.0",
    "expo-font": "~55.0.4",
    "expo-image-picker": "^55.0.11",
    "expo-location": "~55.1.2",
    "expo-status-bar": "~55.0.4",
    "firebase": "^12.10.0",
    "react": "19.2.0",
    "react-dom": "^19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-web": "^0.21.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-native": "^5.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.9",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect"
    ],
    "transformIgnorePatterns": [
      "/node_modules/(?!(.pnpm|react-native|@react-native|@react-native-community|expo|@expo|@expo-google-fonts|react-navigation|@react-navigation|firebase|@firebase|zustand))"
    ],
    "moduleNameMapper": {
      "^@expo/vector-icons$": "<rootDir>/__mocks__/@expo/vector-icons.js",
      "^@expo/vector-icons/(.*)$": "<rootDir>/__mocks__/@expo/vector-icons.js",
      "^firebase/(.*)$": "<rootDir>/__mocks__/firebase.js",
      "^@firebase/(.*)$": "<rootDir>/__mocks__/firebase.js",
      "^../services/authService$": "<rootDir>/__mocks__/authService.js",
      "^../services/firebase$": "<rootDir>/__mocks__/firebaseService.js",
      "^@react-native-async-storage/async-storage$": "<rootDir>/__mocks__/@react-native-async-storage/async-storage.js",
      "^expo-document-picker$": "<rootDir>/__mocks__/expo-document-picker.js",
      "^expo-file-system$": "<rootDir>/__mocks__/expo-file-system.js"
    },
    "collectCoverageFrom": [
      "app/**/*.{ts,tsx}",
      "!app/**/*.d.ts"
    ]
  },
  "private": true
}
